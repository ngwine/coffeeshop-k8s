# ============================================================
# CoffeeShop — Terraform Variables Example (DigitalOcean)
# Copy this file to terraform.tfvars and fill in your values
# ============================================================

# DigitalOcean API Token (generate at https://cloud.digitalocean.com/account/api/tokens)
do_token = "dop_v1_YOUR_DIGITALOCEAN_API_TOKEN"

# SSH key name (must match a key registered in DigitalOcean → Settings → Security)
ssh_key_name = "coffeeshop-deploy"

# SSH public key content (paste your public key)
ssh_public_key = "ssh-rsa AAAAB3NzaC1yc2EAAAADAQ... your-key"

# Project
project_name = "coffeeshop"

# Region (sgp1 = Singapore)
region = "sgp1"

# Droplet size (s-2vcpu-4gb recommended for K3s)
droplet_size = "s-2vcpu-4gb"

# Domain
domain_name = "coffeeshopk8s.me"

# VPC CIDR
vpc_cidr = "10.10.10.0/24"
